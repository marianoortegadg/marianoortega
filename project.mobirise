            ".mbr-text": {
              "color": "#e9e8dd",
              "text-align": "right"
            },
            ".mbr-section-subtitle": {
              "color": "#000000",
              "text-align": "center"
            },
            ".mbr-section-title": {
              "text-align": "center",
              "color": "#000000"
            },
            ".content-head": {
              "max-width": "800px"
            },
            ".mbr-card-subtitle": {
              "color": "#e9e8dd",
              "text-align": "left"
