            ".mbr-text, .item .mbr-section-btn": {
              "text-align": "left",
              "color": "#edefeb"
            },
            ".item-wrapper": {
              "background": "@cardbg",
              "margin-bottom": "2rem",
              "padding": "2.25rem",
              "@media (min-width: 992px) and (max-width: 1200px)": {
                "padding": "2rem 1.5rem",
