              "color": "#e9e8dd",
              "text-align": "right"
            }
          },
          "_name": "article15",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article15\" group=\"Article\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"checkbox\" name=\"reverseContent\" title=\"Reverse\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"1\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"2\">\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"8\" value=\"6\" step=\"1\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\">\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <header>Background</header>\n        <input type=\"color\" title=\"Color\" name=\"bgColor\" value=\"#2c312d\">\n    </mbr-parameters>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-md\">\n                <h5 class=\"mbr-section-title mbr-fonts-style mt-0 mb-4\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\">\n                <b>Photography as Narrative</b>\n                </h5>\n                <h6 class=\"mbr-section-subtitle mbr-fonts-style mt-0 mb-4\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-5\"><b>Mariano Ortega Castro</b><br><i>Estudiante avanzado de </i><br><i>Diseño Gráfico</i></h6>\n            </div>\n            <div class=\"col-md-12 col-lg-{{textWidth}}\">\n              <p class=\"mbr-text mbr-fonts-style mt-0 mb-0\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\">Mariano Ortega Castro nació en San Juan, Argentina, el 6 de abril de 2002. Es estudiante de quinto año de la carrera de Diseño Gráfico en la Facultad de Arquitectura, Urbanismo y Diseño de la Universidad Nacional de San Juan (UNSJ), actualmente realizando su tesis. <br><br>Cuenta con educación secundaria completa con orientación en Economía y Gestión Empresarial por el Colegio Medalla Milagrosa, y ha complementado su formación académica con un curso de Diseño Gráfico en el Instituto Superior Cervantes. Forma parte del Cuerpo de Bandera de la FAUD-UNSJ como Primer Escolta del periodo 2025 - 2026. También se desempeña como pasante de diseño gráfico en la Secretaría de Extensión de la UNSJ.\n<br>\n<br>Su filosofía de trabajo se basa en la solución de problemas de comunicación visual a partir de la creación de piezas de diseños funcionales y lógicas, combinado a flujos de trabajo orgánicos y genuinos — poniendo en valor el criterio y la naturaleza humana — en un entorno saturado de respuestas automáticas y cortoplacistas.&nbsp;&nbsp;<br></p>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "vmDdPjaqvc",
          "_anchor": "article15-35",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
